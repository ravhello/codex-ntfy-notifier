root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{json,yml,yaml}]
indent_style = space
indent_size = 2

[*.py]
indent_style = space
indent_size = 4

[*.{ps1,sh,vbs}]
indent_style = space
indent_size = 2

[*.ps1]
end_of_line = crlf

[*.vbs]
end_of_line = crlf

[*.md]
trim_trailing_whitespace = false
